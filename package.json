{
  "name": "liminal-salt",
  "version": "0.10.10",
  "description": "Tailwind CSS build tooling for Liminal Salt.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n tailwind,server -c blue,green \"npm run watch:css\" \"cargo run -p liminal-salt\"",
    "watch:css": "npx @tailwindcss/cli -i ./crates/liminal-salt/static/css/input.css -o ./crates/liminal-salt/static/css/output.css --watch --minify",
    "build:css": "npx @tailwindcss/cli -i ./crates/liminal-salt/static/css/input.css -o ./crates/liminal-salt/static/css/output.css --minify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/irvj/liminal-salt.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/irvj/liminal-salt/issues"
  },
  "homepage": "https://github.com/irvj/liminal-salt#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.18"
  }
}
