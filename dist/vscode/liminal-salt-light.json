	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#6b6762",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keyword",
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier",
				"keyword.control"
			],
			"settings": {
				"foreground": "#506e58"
			}
		},
		{
			"name": "Function",
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call"
			],
			"settings": {
				"foreground": "#425f4a"
			}
		},
		{
			"name": "String",
			"scope": [
				"string",
				"string.quoted"
			],
			"settings": {
				"foreground": "#7d6325"
			}
		},
		{
			"name": "Number",
			"scope": [
				"constant.numeric"
			],
			"settings": {
				"foreground": "#3a6f80"
			}
		},
		{
			"name": "Type",
			"scope": [
				"entity.name.type",
				"support.type",
				"entity.name.class",
				"support.class"
			],
			"settings": {
				"foreground": "#3e6b5d"
			}
		},
		{
			"name": "Variable",
			"scope": [
				"variable",
				"variable.other"
			],
			"settings": {
				"foreground": "#2d2b28"
			}
		},
		{
			"name": "Constant",
			"scope": [
				"constant",
				"constant.language",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#3a6f80"
			}
		},
		{
			"name": "Operator",
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#5a5753"
			}
		},
		{
			"name": "Punctuation",
			"scope": [
				"punctuation",
				"meta.brace",
				"punctuation.definition.tag"
			],
			"settings": {
				"foreground": "#5a5753"
			}
		},
		{
			"name": "Tag",
			"scope": [
				"entity.name.tag",
				"support.tag"
			],
			"settings": {
				"foreground": "#a54d4d"
			}
		},
		{
			"name": "Attribute",
			"scope": [
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#7d6325"
			}
		},
		{
			"name": "Regex",
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#5c6135"
			}
		},
		{
			"name": "Escape",
			"scope": [
				"constant.character.escape"
			],
			"settings": {
				"foreground": "#8a5c30"
			}
		},
		{
			"name": "Inserted",
			"scope": [
				"markup.inserted"
			],
			"settings": {
				"foreground": "#3a7346"
			}
		},
		{
			"name": "Deleted",
			"scope": [
				"markup.deleted"
			],
			"settings": {
				"foreground": "#a54d4d"
			}
		},
		{
			"name": "Markup Heading",
			"scope": [
				"markup.heading",
				"entity.name.section"
			],
			"settings": {
				"foreground": "#506e58",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markup Bold",
			"scope": [
				"markup.bold"
			],
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markup Italic",
			"scope": [
				"markup.italic"
			],
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"name": "Markup Link",
			"scope": [
				"markup.underline.link",
				"string.other.link"
			],
			"settings": {
				"foreground": "#3e6b5d"
			}
		}
	]
}
