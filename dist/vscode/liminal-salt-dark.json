	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#9e9b93",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keyword",
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier",
				"keyword.control"
			],
			"settings": {
				"foreground": "#8fac98"
			}
		},
		{
			"name": "Function",
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call"
			],
			"settings": {
				"foreground": "#a3bfac"
			}
		},
		{
			"name": "String",
			"scope": [
				"string",
				"string.quoted"
			],
			"settings": {
				"foreground": "#c9a86c"
			}
		},
		{
			"name": "Number",
			"scope": [
				"constant.numeric"
			],
			"settings": {
				"foreground": "#7eb8c9"
			}
		},
		{
			"name": "Type",
			"scope": [
				"entity.name.type",
				"support.type",
				"entity.name.class",
				"support.class"
			],
			"settings": {
				"foreground": "#8fb8ad"
			}
		},
		{
			"name": "Variable",
			"scope": [
				"variable",
				"variable.other"
			],
			"settings": {
				"foreground": "#e8e4dc"
			}
		},
		{
			"name": "Constant",
			"scope": [
				"constant",
				"constant.language",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#7eb8c9"
			}
		},
		{
			"name": "Operator",
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#c5c1b8"
			}
		},
		{
			"name": "Punctuation",
			"scope": [
				"punctuation",
				"meta.brace",
				"punctuation.definition.tag"
			],
			"settings": {
				"foreground": "#c5c1b8"
			}
		},
		{
			"name": "Tag",
			"scope": [
				"entity.name.tag",
				"support.tag"
			],
			"settings": {
				"foreground": "#cc8585"
			}
		},
		{
			"name": "Attribute",
			"scope": [
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#c9a86c"
			}
		},
		{
			"name": "Regex",
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#a9ad78"
			}
		},
		{
			"name": "Escape",
			"scope": [
				"constant.character.escape"
			],
			"settings": {
				"foreground": "#c9956c"
			}
		},
		{
			"name": "Inserted",
			"scope": [
				"markup.inserted"
			],
			"settings": {
				"foreground": "#7dba8a"
			}
		},
		{
			"name": "Deleted",
			"scope": [
				"markup.deleted"
			],
			"settings": {
				"foreground": "#cc8585"
			}
		},
		{
			"name": "Markup Heading",
			"scope": [
				"markup.heading",
				"entity.name.section"
			],
			"settings": {
				"foreground": "#8fac98",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markup Bold",
			"scope": [
				"markup.bold"
			],
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markup Italic",
			"scope": [
				"markup.italic"
			],
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"name": "Markup Link",
			"scope": [
				"markup.underline.link",
				"string.other.link"
			],
			"settings": {
				"foreground": "#8fb8ad"
			}
		}
	]
}
